# Configuration reference for supported environment overrides.
# The installer writes only the DB_* keys to .env. Add other values as needed.

APP_NAME=Copot
APP_ENV=local
# Local development uses a 30-day session lifetime; non-local environments default to 120 minutes.
APP_DEBUG=true
APP_URL=http://localhost
SESSION_SECURE=false

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=copot
DB_USERNAME=root
DB_PASSWORD=
